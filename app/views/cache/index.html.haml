= stylesheet_link_tag 'cache'

%h1 Cached items

#cached_items
  - CACHED_ITEMS.each do |cache_item|
    :ruby
      cache_name = cache_item.first
      cache_key = cache_item[1]
      cache_subkeys = []
      if cache_item[2]
        cache_subkeys = cache_item[2]
      end
    .row.mb-5
      .col-lg-3.cache_name
        = link_to cache_name, cache_path(id: cache_key), method: :put
      .col-lg-4.cache_time
        - time = Rails.cache.read(cache_key)
        expires: #{time ? time.localtime.to_fs(:precise) : 'expired!'}
      - unless cache_subkeys.empty?
        - cache_subkeys.each do |subcache|
          .row.ms-3.mb-1
            .col-lg-3.cache_name
              = subcache
            .col-lg-4.cache_time
              - time = Rails.cache.read(subcache)
              = time ? "expires #{time.localtime.to_fs(:precise)}" : 'not set'
